{
  "version": 1,
  "protectedPaths": [
    "examples/reference/**",
    "vendor/**"
  ],
  "blockUnresolvedWrites": false,
  "checks": [
    {
      "name": "project tests",
      "whenChanged": [
        "src/**",
        "tests/**"
      ],
      "run": [
        "npm",
        "test"
      ],
      "cwd": ".",
      "timeoutSeconds": 120
    }
  ]
}
