{
  "name": "odai-cli",
  "version": "0.0.2",
  "description": "Provider-neutral odai CLI agent runtime.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orziz/odai.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/orziz/odai#readme",
  "bugs": {
    "url": "https://github.com/orziz/odai/issues"
  },
  "type": "module",
  "main": "./src/api.mjs",
  "exports": {
    ".": "./src/api.mjs",
    "./cli": "./src/index.mjs",
    "./interactive": "./src/core/interactive-session.mjs",
    "./i18n": "./src/runtime/i18n.mjs",
    "./model-options": "./src/runtime/model-options.mjs",
    "./update-check": "./src/runtime/update-check.mjs",
    "./package.json": "./package.json"
  },
  "bin": {
    "odai": "bin/odai.mjs"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "bin",
    "src",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "find . -name '*.mjs' -print0 | xargs -0 -n1 node --check",
    "prepare:skill-bundle": "node ./scripts/package-skill-bundle.mjs prepare",
    "clean:skill-bundle": "node ./scripts/package-skill-bundle.mjs clean",
    "prepack": "node ../scripts/validate-odai-skill.mjs && node ./scripts/package-skill-bundle.mjs prepare",
    "postpack": "node ./scripts/package-skill-bundle.mjs clean",
    "prepublishOnly": "node ../scripts/validate-odai-skill.mjs",
    "phase0": "node ./bin/odai.mjs phase0",
    "providers": "node ./bin/odai.mjs providers",
    "pack:dry-run": "node ./scripts/run-pack.mjs --dry-run",
    "smoke": "node ./tests/phase0/smoke.mjs",
    "test:optimizations": "node ./tests/phase0/optimizations.mjs",
    "test": "node ./tests/phase0/smoke.mjs && node ./tests/phase0/optimizations.mjs"
  },
  "keywords": [
    "agent",
    "cli",
    "llm",
    "odai",
    "orchestration"
  ],
  "engines": {
    "node": ">=20"
  }
}
